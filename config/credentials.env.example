# podcast-transcriber 凭证配置
# 复制此文件为 credentials.env 并填入你的密钥

# 火山引擎豆包语音 ASR
# 获取地址: https://console.volcengine.com/speech/new/setting/apikeys
VOLC_ASR_KEY=
VOLC_ASR_RESOURCE_ID=volc.seedasr.auc

# 火山引擎 TOS 对象存储
# 获取地址: https://console.volcengine.com/iam/keymanage/
VOLC_TOS_AK=
VOLC_TOS_SK=
VOLC_TOS_BUCKET=
VOLC_TOS_ENDPOINT=tos-cn-beijing.volces.com
VOLC_TOS_REGION=cn-beijing

# Groq Whisper (短音频免费 fallback)
# 获取地址: https://console.groq.com/keys
GROQ_API_KEY=
